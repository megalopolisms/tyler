rules_version = '2';

// Tyler Trips — Firestore security rules.
//
// Threat model: single-user app gated by a client-side password. After the
// password check, the web app calls signInAnonymously(), giving the user a
// Firebase UID. These rules require any read/write to come from an
// authenticated user (i.e. someone who passed the password gate).
//
// What this protects against:
//   - Random web crawlers / unauthenticated GET requests
//   - Direct Firestore REST API calls without an ID token
//
// What this does NOT protect against (acceptable per Yuri):
//   - A determined attacker who reverse-engineers the password from the JS
//   - Anyone with physical access to Tyler's unlocked phone
service cloud.firestore {
  match /databases/{db}/documents {
    match /expenses/{id} {
      allow read, write: if request.auth != null;
    }
    match /categories/{id} {
      allow read, write: if request.auth != null;
    }
    match /tags/{id} {
      allow read, write: if request.auth != null;
    }
  }
}
