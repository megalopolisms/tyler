rules_version = '2';

// Tyler Trips — Firebase Storage security rules.
//
// Receipts live at receipts/{expenseId}.jpg. Same auth gate as Firestore:
// signed-in users only (i.e. anyone who passed the password gate).
//
// 2 MB hard cap on uploads — a compressed receipt is ~150 KB; cap stops
// runaway uploads or accidental video files.
service firebase.storage {
  match /b/{bucket}/o {
    match /receipts/{file=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
